{
  "name": "@wynillo/echoes-mod-base",
  "version": "1.0.2",
  "description": "Base TCG package for Echoes of Sanguo — contains the complete base card set, opponents, campaign, and all game data",
  "type": "module",
  "main": "./dist/base.tcg",
  "exports": {
    "./tcg": "./dist/base.tcg"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:tcg": "node -e \"require('fs').mkdirSync('dist',{recursive:true})\" && tcg-format pack ./tcg-src -o ./dist/base.tcg",
    "validate": "tcg-format validate ./tcg-src",
    "prepare": "npm run build:tcg"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Wynillo/Echoes-of-sanguo-MOD-base.git"
  },
  "author": "Wynillo",
  "license": "MIT",
  "dependencies": {
    "@wynillo/tcg-format": "github:Wynillo/Echoes-of-Sanguo-TCG#main"
  }
}
